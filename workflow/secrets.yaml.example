# Sentinel CRE Workflow Secrets Template
# Copy this file to secrets.yaml and fill in your actual values
# NEVER commit secrets.yaml to git!

# Etherscan API Key for fetching contract source code
# Get one at: https://etherscan.io/apis
etherscanApiKey: "YOUR_ETHERSCAN_API_KEY"

# xAI Grok API Key for AI security analysis
# Get one at: https://x.ai/api
grokApiKey: "YOUR_GROK_API_KEY"

# Contract Addresses (Sepolia Testnet)
# Deploy contracts first, then fill these in
guardianContractAddress: "0x..."
auditLoggerAddress: "0x..."
registryContractAddress: "0x..."

# Transaction Settings
maxFeePerGas: "50000000000"  # 50 gwei
maxPriorityFeePerGas: "2000000000"  # 2 gwei

# Webhook Security
errorWebhook: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
webhookSecret: "your_webhook_signing_secret"

# Optional: Custom RPC endpoints for better reliability
# customRpcUrl: "https://your-custom-rpc.com"
