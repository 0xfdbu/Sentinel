# ============================================
# Network Configuration
# ============================================
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/DFCXUzLyQhp00HIXt2NTo
CHAIN_ID=11155111

# ============================================
# Contract Addresses (Sepolia)
# ============================================
REGISTRY_ADDRESS=0x774B96F8d892A1e4482B52b3d255Fa269136A0E9
GUARDIAN_ADDRESS=0xD1965D40aeAAd9F1898F249C9cf6b2b74c3B5AE1

# ============================================
# CRE (Chainlink Functions) Configuration
# ============================================

# Your subscription ID from functions.chain.link
CHAINLINK_SUBSCRIPTION_ID=1234

# Deployed CREConsumer contract address (after running deploy-cre-consumer.js)
CRE_CONSUMER_ADDRESS=0xYOUR_DEPLOYED_CONSUMER_ADDRESS

# DON ID for Sepolia (usually doesn't change)
DON_ID=0x66756e2d657468657265756d2d7365706f6c69612d3100000000000000000000

# API key for authenticating Chainlink Functions requests
SENTINEL_API_KEY=your-secure-random-api-key

# ============================================
# Sentinel Node Authentication
# ============================================

# Private key for executing pauses (must be authorized in Guardian)
# ⚠️ Keep this secret! Use a dedicated wallet with limited funds.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Comma-separated list of authorized sentinel node addresses
ALLOWED_SENTINELS=0x...

# ============================================
# Optional: Database (Supabase)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_key

# ============================================
# Server Configuration
# ============================================
WS_PORT=8080
API_PORT=3000

# ============================================
# Deprecated: Old CRE Webhook (use Functions instead)
# ============================================
# CRE_WEBHOOK_URL=https://...
# CRE_API_KEY=...
