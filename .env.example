# ==========================================================================
# SENTINEL - CHAINLINK CRE WORKFLOW ENVIRONMENT
# ==========================================================================
# These variables are used for local CRE simulation.
# In production, secrets are resolved from the Vault DON.
# ==========================================================================

# ==========================================================================
# API KEYS (Required)
# ==========================================================================

# Etherscan API Key - Get from https://etherscan.io/apis
# Used for: Fetching contract source code
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# xAI Grok API Key - Get from https://x.ai/api
# Used for: AI security analysis
GROK_API_KEY=your_grok_api_key_here

# ==========================================================================
# ENCRYPTION KEYS (Required for Confidential Compute)
# ==========================================================================

# AES-256-GCM key for encrypting workflow outputs
# Generate with: openssl rand -hex 32
# Must be 64 hex characters (32 bytes)
AES_KEY_ALL=your_64_character_hex_key_here

# Alternative name used by some workflows
sentinelEncryptionKey=${AES_KEY_ALL}

# ==========================================================================
# BLOCKCHAIN KEYS (Required for Emergency Pause)
# ==========================================================================

# Sentinel private key for signing transactions
# This address must be authorized in SentinelRegistry
# Format: 0x + 64 hex characters
SENTINEL_PRIVATE_KEY=your_private_key_here

# Alternative name
sentinelPrivateKey=${SENTINEL_PRIVATE_KEY}

# ==========================================================================
# WEBHOOK CONFIGURATION (Optional)
# ==========================================================================

# Secret for signing webhook notifications
WEBHOOK_SECRET=your_webhook_secret_here

# Webhook URL for alerts
WEBHOOK_URL=https://your-app.com/webhook

# ==========================================================================
# RPC ENDPOINTS
# ==========================================================================

# Hardhat local node
HARDHAT_RPC=http://127.0.0.1:8545

# Sepolia testnet (public node as fallback)
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Mainnet (for production)
MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ==========================================================================
# WORKFLOW OWNER (Required for production)
# ==========================================================================

# Address that owns the workflow in the Vault DON
WORKFLOW_OWNER_ADDRESS=0x89feEbA43b294425C0d7B482770eefbcc1359f8d

# ==========================================================================
# CONTRACT ADDRESSES (Sepolia Testnet)
# ==========================================================================

# Core Sentinel Contracts
SEPOLIA_REGISTRY_ADDRESS=0x774B96F8d892A1e4482B52b3d255Fa269136A0E9
SEPOLIA_GUARDIAN_ADDRESS=0xD1965D40aeAAd9F1898F249C9cf6b2b74c3B5AE1
SEPOLIA_AUDIT_LOGGER_ADDRESS=0x12DfF0223Cf652091b2360Ecf1592EDB696F3cbD

# Risk & Compliance Contracts (New)
SEPOLIA_MOCK_ERC20=0xEa9dfB83A202253B79A6C23A0B40a2e786CF06D3
SEPOLIA_PAUSABLE_VULNERABLE_VAULT=0xc7CD6F13A4bE91604BCc04A78f57531d30808D1C
SEPOLIA_REENTRANCY_ATTACKER=0x44EF43391d83B6c89Eba95591329fEAD9fC24ED8
SEPOLIA_RESERVE_HEALTH_MONITOR=0x4fDC65D9B02df818d3BcA82cd1d5dc6Be7D8838a
SEPOLIA_RISK_PROFILE_REGISTRY=0x33d347Fbe9552Dbafb2005b4c59793fEc4bdD643

# ==========================================================================
# DEVELOPMENT SETTINGS
# ==========================================================================

# Node environment
NODE_ENV=development

# CRE simulation mode (true for local development)
CRE_SIMULATE=true

# Log level
LOG_LEVEL=info
